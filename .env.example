# ===== WebTutorCenter Chatbot Service — mẫu cấu hình =====
# Copy file này thành `.env` rồi điền giá trị thật. KHÔNG commit `.env`.

# --- AI provider (Groq, OpenAI-compatible, free tier) ---
# Lấy key tại https://console.groq.com/keys
GROQ_API_KEY=
AI_MODEL=llama-3.3-70b-versatile
AI_TEMPERATURE=0.3
AI_MAX_TOKENS=512

# --- Engine ---
# Rule nào đạt confidence >= ngưỡng này sẽ trả lời luôn, không gọi AI.
RULE_CONFIDENCE_THRESHOLD=0.6
# Số FAQ nhét vào prompt AI làm ngữ cảnh (RAG-lite).
FAQ_CONTEXT_K=3
CACHE_TTL_SECONDS=3600
CACHE_MAX_SIZE=512

# --- Backend WebTutorCenter (resolver gọi ngược lấy dữ liệu app) ---
BACKEND_BASE_URL=http://localhost:5002/api
INTERNAL_SECRET=
REQUEST_TIMEOUT=15

# --- HTTP server ---
HOST=0.0.0.0
PORT=8001
CORS_ORIGINS=http://localhost:4000,http://localhost:5002
LOG_LEVEL=INFO
